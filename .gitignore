# .gitignore for DictionaryMark — C# .NET project with Python and Node tools

# Build outputs
bin/
obj/
artifacts/

# .NET
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.slnx.user
.vs/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
**/packages/*

# MSTest / NUnit test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
TestResults/
*.trx
*.xml
coverage.opencover.xml

# Python virtual environment
.venv/
__pycache__/
*.py[cod]
*$py.class

# Node
node_modules/
package-lock.json
npm-debug.log

# Generated compliance documents (build outputs — never committed)
**/generated/

# VersionMark captures (generated during CI/CD)
versionmark-*.json

# Agent logs
.agent-logs/

# Temporary files
*.tmp
*.temp
*.log

# OS
.DS_Store
Thumbs.db
